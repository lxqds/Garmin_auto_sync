# ===== WorkBuddy 内部文件（含个人记忆/笔记，勿提交） =====
.workbuddy/

# ===== Python 缓存 =====
__pycache__/
*.pyc
*.pyo
*.pyd

# ===== 打包产物（由源码生成，无需入库） =====
garmin-sync.zip

# ===== 个人健康数据与原始运动记录（隐私，勿提交） =====
# 聚合趋势/每日健康摘要
garmin-data/health_*
garmin-data/summary.md
# 佳明教练训练计划（个人训练数据，勿提交）
garmin-data/coach_plan.md
# 生成的个人图表（含睡眠/恢复数据，勿提交）
garmin-data/sleep_quality.html
garmin-data/health_trend.html
# 跑步活动分析报告与归档（个人数据，勿提交）
garmin-data/reports/
garmin-data/processed/
# 原始活动文件
garmin-data/inbox/*.fit
garmin-data/inbox/*.tcx
garmin-data/inbox/*.gpx
# 令牌/配置/状态由 garmin-data/.gitignore 处理

# ===== 环境变量/密钥（含 API key，勿提交） =====
.env
.env.*
!.env.example

# ===== 编辑器/系统 =====
.idea/
.vscode/
.DS_Store
